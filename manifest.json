{
  "manifest_version": 3,
  "name": "Open Multiple URLs",
  "version": "2.0",
  "description": "Paste multiple URLs and open them all in new tabs instantly.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
